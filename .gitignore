# Rust
/target
**/*.rs.bk
Cargo.lock.bak

# macOS
.DS_Store
._*
.Spotlight-V100
.Trashes

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Node / Tauri (will be added when we scaffold the app)
node_modules/
/app/src-tauri/target/
/app/node_modules/
/app/dist/

# Swift Package Manager build artifacts
/swift/**/.build/
/swift/**/Package.resolved
/swift/**/.swiftpm/
# Generated uniffi Swift bindings — the *canonical* copies live under
# swift/UnovaultFFI/Sources/{UnovaultFFI,UnovaultFFIC}/. The swift/generated/
# directory is a scratch space for regeneration runs.
/swift/generated/

# Secrets — never commit a real vault
*.unovault
!design/**/*.unovault/
*.unovault-backup
/.env
/.env.local

# Design spike artifacts that are generated, not authored
/design/spike/generated/
