{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["chrome"],
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["src/**/*.ts", "popup/**/*.ts"],
  "exclude": ["node_modules", "dist", "vite.config.ts"]
}
